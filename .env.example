# vanish secrets — template. Copy to `.env` (which is gitignored) for local use.
#
# IMPORTANT: vanish reads HIBP_API_KEY from the ENVIRONMENT only. It does NOT
# read this file (or any file) itself — that's deliberate, so a key can't be
# committed by accident. If you keep a local `.env`, load it into your shell
# yourself before running vanish, e.g.:
#
#     set -a; . ./.env; set +a
#     vanish audit --email you@example.com
#     unset HIBP_API_KEY
#
# Never pass the key as a CLI flag (it would land in shell history) and never
# commit a real key. `.env` is gitignored and GitHub push protection is on.

HIBP_API_KEY=
