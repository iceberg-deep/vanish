# Virtual environments
.venv/
venv/

# Python build/packaging artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/

# Secrets — vanish reads HIBP_API_KEY from the environment only and never reads
# a .env file, but ignore these defensively so a key can never be committed.
.env
.env.*
*.env
# ...except the committed template, which holds no value.
!.env.example

# Local vanish runtime data (never belongs in the repo)
.vanish/
vanish-removal-guide.md

# OS / editor cruft
.DS_Store
*.swp
